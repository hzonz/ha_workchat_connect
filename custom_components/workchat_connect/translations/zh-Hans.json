      "unknown": "发生未知错误"
    },
    "abort": {
      "already_configured": "该企业应用 (Agent ID) 已经配置过，请勿重复添加",
      "reconfigure_successful": "重新配置成功"
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "修改企微通设置",
        "data": {
          "receive_user": "默认接收人",
          "proxy": "代理地址"
        }
      }
    }
  },
  "entity": {
    "sensor": {
      "text_message": { 
        "name": "文本消息",
        "state_attributes": {
