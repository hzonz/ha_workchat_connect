          "raw_info": { "name": "原始信息" }
        }
      },
      "location_message": { 
        "name": "位置消息",
        "state_attributes": {
          "from_user": { "name": "用户" },
          "receive_time": { "name": "接收时间" },
          "latitude": { "name": "纬度" },
          "longitude": { "name": "经度" },
          "address": { "name": "地理位置" },
          "raw_info": { "name": "原始信息" }
        }
      },
      "menu_click": { 
        "name": "菜单交互",
        "state":{
          "Menu Message": "菜单消息"
        },
        "state_attributes": {
          "from_user": { "name": "用户" },
          "receive_time": { "name": "接收时间" },
          "agent_id": { "name": "应用 ID" },
          "raw_info": { "name": "原始信息" }
        }
      },
      "callback_info": { 
        "name": "回调状态",
        "state": {
          "Connected": "已连接",
          "Disconnected": "断开连接" 
        },
        "state_attributes": {
          "webhook_url": { "name": "回调地址" },
          "corpid": { "name": "企业 ID" },
          "last_msg_received": { "name": "最后收到信息时间" },
          "agent_id": { "name": "应用 ID" },
