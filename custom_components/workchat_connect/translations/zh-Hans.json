          "receive_time": { "name": "接收时间" },
          "agent_id": { "name": "应用 ID" },
          "raw_info": { "name": "原始信息" }
        }
      },
      "voice_message": { 
        "name": "语音消息",
        "state":{
          "Voice message": "语音消息"
        },
        "state_attributes": {
          "from_user": { "name": "用户" },
          "receive_time": { "name": "接收时间" },
          "agent_id": { "name": "应用 ID" },
