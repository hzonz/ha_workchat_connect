          "local_path": { "name": "本地路径" },
          "raw_info": { "name": "原始信息" }
        }
      },
      "image_message": { 
        "name": "图片消息",
        "state":{
          "Image message": "图片消息"
        },
        "state_attributes": {
          "from_user": { "name": "用户" },
          "receive_time": { "name": "接收时间" },
